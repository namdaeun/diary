{
  "name": "diary-monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "pnpm run dev:web & pnpm run dev:api",
    "dev:web": "pnpm --filter client dev",
    "dev:api": "pnpm --filter api-server dev",
    "build": "pnpm --parallel build:web build:api",
    "build:web": "pnpm --filter client build",
    "build:api": "pnpm --filter api-server build",
    "typecheck": "pnpm --filter client typecheck",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
